# MetaCypher runtime configuration.
# Copy to `.env` and edit, or export these variables in your shell.
# All variables are optional; the defaults shown in config.py assume a local
# layout under <repo>/data and local services.

# ---- Data root (datasets, schemas, embeddings, intermediate artifacts) ----
# Point this at wherever you unpacked the benchmark data.
METACYPHER_DATA_DIR=./data

# Optional per-directory overrides (default to subdirs of METACYPHER_DATA_DIR):
# METACYPHER_DATASET_DIR=./data/dataset/MindtheQuery
# METACYPHER_SCHEMA_DIR=./data/schema
# METACYPHER_SANDBOX_SCHEMA_DIR=./data/schema/sandbox_schemas
# METACYPHER_TEMPLATE_DIR=./data/schema/template/schema_with_template
# METACYPHER_SUBGRAPH_DIR=./data/subgraph
# METACYPHER_OUTPUT_DIR=./data/outputs

# ---- Embedding model + FAISS attribute index ----
# Hugging Face id (downloads on first use) or a local path for offline runs.
METACYPHER_EMBED_MODEL=BAAI/bge-m3
# METACYPHER_FAISS_INDEX_DIR=./data/faiss_search/index

# ---- LLM endpoint (OpenAI-compatible, e.g. a local vLLM server) ----
METACYPHER_VLLM_BASE_URL=http://localhost:8000/v1
METACYPHER_VLLM_MODEL=local_llm
METACYPHER_VLLM_API_KEY=EMPTY

# Hosted alternative — the ECNU OpenAI-compatible endpoint works as a drop-in
# backbone (verified): set the three variables to
#   METACYPHER_VLLM_BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
#   METACYPHER_VLLM_MODEL=ecnu-plus        # or ecnu-max
#   METACYPHER_VLLM_API_KEY=<your key>     # keep it out of git

# ---- Neo4j (CypherBench / MindtheQuery sandbox graphs) ----
# Host + credentials are shared across the per-graph bolt port mapping.
NEO4J_HOST=localhost
NEO4J_USER=neo4j
NEO4J_PASSWORD=cypherbench
